        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un assistant métier d'un système de livraison COD en Tunisie. À partir de la question d'origine et des données réelles fournies, tu rédiges UNE phrase courte et claire en français qui répond à la question. N'invente pas de chiffres, n'ajoute pas de spéculations. Si les données sont vides, dis-le. Pas d'emojis, pas de salutations.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.prompt) }}\n    }\n  ],\n  \"temperature\": 0.2\n}",
        "options": {}
      },
      "id": "groq-format-1",
      "name": "Groq — Format response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1700, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "groq-credentials",
          "name": "Groq API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Construit le prompt de reformulation à partir de l'intent + data\nconst all = $('Parse intent JSON').first().json;\nconst data = $json;\nconst prompt = `Question : ${all.originalQuestion}\\n\\nIntention détectée : ${all.intent}\\n\\nDonnées brutes :\\n${JSON.stringify(data, null, 2)}`;\nreturn [{ json: { prompt, intent: all.intent, data } }];"
      },
      "id": "build-prompt",
      "name": "Build reformulation prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 300]
    },
    {
      "parameters": {
        "jsCode": "// Construit la réponse finale Flutter\nconst groqText = $json.choices?.[0]?.message?.content || 'Données reçues.';\nconst built = $('Build reformulation prompt').first().json;\nreturn [{ json: {\n  success: true,\n  message: groqText,\n  intent: built.intent,\n  data: built.data,\n  ui: { type: 'text', show_table: false, show_chart: false }\n}}];"
      },
      "id": "final-response",
      "name": "Build final JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1900, 300]
