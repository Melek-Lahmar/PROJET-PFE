    {
      "parameters": {
        "jsCode": "// Validation du payload Flutter\nconst body = $json.body || $json;\nconst question = (body.question || '').toString().trim();\nif (!question) {\n  throw new Error('question is required');\n}\nreturn [{ json: { question, sessionId: body.sessionId || null } }];"
      },
      "id": "validate-1",
      "name": "Validate payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un parseur d'intentions pour un chatbot métier de livraison COD en Tunisie. Tu analyses la question et tu retournes EXCLUSIVEMENT un objet JSON avec ces champs : intent (string parmi: get_orders_count, list_orders, get_claims_count, list_claims, top_products, governorate_stats, order_detail, fallback), entity (orders|claims|products|governorates), filters (object avec status (pending|confirmed|tentative|refused|inDelivery|delivered|returned|postponed|all|unhandled), period (today|7d|30d|3m|12m), governorate (string ou null), order_number (string ou null), client_query (string ou null), product_query (string ou null)), needs_table (bool), needs_chart (bool). Tunisie : gouvernorats reconnus = Ariana, Beja, BenArous, Bizerte, Gabes, Gafsa, Jendouba, Kairouan, Kasserine, Kebili, Kef, Mahdia, Manouba, Medenine, Monastir, Nabeul, Sfax, SidiBouzid, Siliana, Sousse, Tataouine, Tozeur, Tunis, Zaghouan. Réponds UNIQUEMENT avec le JSON, sans aucun texte additionnel.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.question) }}\n    }\n  ],\n  \"response_format\": {\"type\": \"json_object\"},\n  \"temperature\": 0\n}",
        "options": {}
      },
      "id": "groq-parse-1",
      "name": "Groq — Parse intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "groq-credentials",
          "name": "Groq API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract intent JSON from Groq response\nconst raw = $json.choices?.[0]?.message?.content || '{}';\nlet intent;\ntry { intent = JSON.parse(raw); } catch { intent = { intent: 'fallback' }; }\nreturn [{ json: { ...intent, originalQuestion: $('Validate payload').item.json.question } }];"
      },
      "id": "parse-intent-1",
      "name": "Parse intent JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "get_orders_count", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "orders_count" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "list_orders", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "list_orders" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "get_claims_count", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "claims_count" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "top_products", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "top_products" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "governorate_stats", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "gov_stats" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "order_detail", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "order_detail" }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "id": "switch-1",
      "name": "Route by intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1120, 300]
    },
