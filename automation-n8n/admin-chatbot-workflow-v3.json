{
  "name": "Admin Chatbot V3 (bilingue + actions + insights)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "admin-chat-v3",
        "options": {
          "rawBody": false
        },
        "responseMode": "responseNode"
