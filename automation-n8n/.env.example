# Variables d'environnement n8n pour le chatbot PFE
# À copier dans n8n → Settings → Variables

# URL de ton backend Web API ASP.NET
# Si n8n et le backend tournent sur le même Windows :
WEBAPI_BASE_URL=https://localhost:7178

# Si n8n est dans Docker et backend sur l'hôte Windows, utilise :
# WEBAPI_BASE_URL=https://host.docker.internal:7178

# Clé API chatbot — DOIT être identique à appsettings.json → Chatbot:ApiKey
CHATBOT_API_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_STRING_FOR_N8N

# Clé Groq Cloud (mettre dans les credentials n8n, pas en variable)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
